{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Jenkins BOM major LTS bumps require manual validation",
      "matchManagers": ["gradle", "gradle-wrapper"],
      "matchPackagePatterns": ["^io\\.jenkins\\.tools\\.bom:bom-"],
      "groupName": "Jenkins BOM",
      "automerge": false
    },
    {
      "description": "Group Kotlin and Kotlin DSL — version is tied to Gradle-embedded Kotlin",
      "matchManagers": ["gradle"],
      "matchPackagePatterns": [
        "^org\\.jetbrains\\.kotlin",
        "^org\\.jetbrains\\.kotlin\\.jvm"
      ],
      "groupName": "Kotlin",
      "automerge": false
    },
    {
      "description": "Automerge patch library bumps after CI passes",
      "matchUpdateTypes": ["patch"],
      "matchManagers": ["gradle"],
      "automerge": true
    },
    {
      "description": "GitHub first-party actions — group and allow 30-day stabilisation before automerge",
      "matchManagers": ["github-actions"],
      "matchDepPatterns": ["^actions/"],
      "groupName": "GitHub Actions (first-party)",
      "minimumReleaseAge": "30 days",
      "automerge": true
    },
    {
      "description": "Gradle actions — group and allow 30-day stabilisation before automerge",
      "matchManagers": ["github-actions"],
      "matchDepPatterns": ["^gradle/"],
      "groupName": "Gradle Actions",
      "minimumReleaseAge": "30 days",
      "automerge": true
    },
    {
      "description": "All other third-party actions — group and allow 30-day stabilisation before automerge",
      "matchManagers": ["github-actions"],
      "excludeDepPatterns": ["^actions/", "^gradle/"],
      "groupName": "Third-party GitHub Actions",
      "minimumReleaseAge": "30 days",
      "automerge": true
    },
    {
      "description": "Gradle wrapper updates — validate checksum, do not automerge",
      "matchManagers": ["gradle-wrapper"],
      "automerge": false
    }
  ]
}
